{
  "name": "testops-companion-backend",
  "version": "1.0.0",
  "description": "TestOps Companion Backend Service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "migrate:dev": "prisma migrate dev",
