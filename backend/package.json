{
  "name": "testops-companion-backend",
  "version": "2.8.1",
  "description": "Backend for TestOps Companion",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "dev:simple": "npm run dev:simple:setup && cp .env.dev .env && nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "dev:simple:setup": "npm run dev:simple:generate && npm run dev:simple:migrate && npm run dev:simple:seed",
    "dev:simple:generate": "rm -rf node_modules/.prisma && cp prisma/schema.dev.prisma prisma/schema.prisma && prisma generate",
    "dev:simple:migrate": "rm -f prisma/dev.db && prisma db push --schema=prisma/schema.dev.prisma --accept-data-loss --force-reset",
    "dev:simple:seed": "node prisma/seed.dev.js",
    "build": "tsc && tsc-alias",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:setup": "node scripts/db-setup.js",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "testops",
    "test",
    "operations",
    "api",
    "backend"
  ],
  "author": "Rotem Ayalon",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@azure/openai": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^5.22.0",
    "@slack/web-api": "^7.13.0",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "jira-client": "^8.2.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.1",
    "octokit": "^3.1.2",
    "openai": "^6.22.0",
    "pg": "^8.16.3",
    "pushover-notifications": "^1.2.3",
    "weaviate-ts-client": "^2.2.0",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.3",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "eslint": "^8.56.0"
  }
}