# Server Configuration
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# Database Configuration
DATABASE_URL=postgresql://testops:testops@localhost:5432/testops_companion
DATABASE_SSL=false

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=combined

# External Services
JENKINS_URL=http://your-jenkins-url
JENKINS_USERNAME=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token

GITHUB_API_TOKEN=your-github-api-token
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Notification Services
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_CHANNEL=your-slack-channel

# Email Configuration
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_USER=your-email-user
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@testops-companion.com
EMAIL_RECIPIENTS=admin@testops-companion.com

# Pushover Configuration
PUSHOVER_USER_KEY=your-pushover-user-key
PUSHOVER_APP_TOKEN=your-pushover-app-token

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Test Management Integration
TESTRAIL_HOST=https://your-instance.testrail.com
TESTRAIL_USERNAME=your-testrail-username
TESTRAIL_API_KEY=your-testrail-api-key

XRAY_CLIENT_ID=your-xray-client-id
XRAY_CLIENT_SECRET=your-xray-client-secret

# Security
BCRYPT_SALT_ROUNDS=12
SECURE_COOKIE=false
SESSION_SECRET=your-session-secret

# Monitoring
SENTRY_DSN=your-sentry-dsn
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# Feature Flags
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_TRACING=false