# Development Mode Environment Variables (SQLite)
# This file is used for demo mode with SQLite database

# Database (SQLite - no Docker needed!)
DATABASE_URL="file:./prisma/dev.db"

# Server
PORT=4000
NODE_ENV=development

# Security (dev keys - NOT for production)
JWT_SECRET="dev-secret-change-in-production-must-be-at-least-32-chars"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-must-be-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis (optional - disabled in dev mode)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false

# Weaviate (optional - disabled in dev mode)
WEAVIATE_HOST=http://localhost:8081
WEAVIATE_ENABLED=false

# AI Providers (optional for demo)
ANTHROPIC_API_KEY=demo-key
OPENAI_API_KEY=demo-key
GOOGLE_API_KEY=demo-key

# AI Configuration
AI_ENABLED=true
# AI_PROVIDER=openai
AI_PROVIDER=mock
AI_MODEL=mock
AI_FEATURE_RCA_MATCHING=true
AI_FEATURE_CATEGORIZATION=true
AI_FEATURE_LOG_SUMMARY=true
AI_FEATURE_TICKET_GENERATION=true

# Giphy (optional — mock mode shows hardcoded GIFs without this; set for varied results)
# Get a free beta key at https://developers.giphy.com/dashboard/
GIPHY_API_KEY=
GIPHY_ENABLED=true
