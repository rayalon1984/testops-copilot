// SQLite Development Schema for Demo Mode
// This is a simplified version using SQLite instead of PostgreSQL
// Note: SQLite doesn't support enums, so we use String with validation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String?
  lastName  String?
  role      String   @default("USER") // ADMIN | USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestRun {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("PENDING")
  branch    String?
  commit    String?
  startTime DateTime?
  endTime   DateTime?
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FailureArchive {
  id                    String           @id @default(uuid())
  testRunId             String
  testCaseId            String?
  testName              String
  failureSignature      String

  // Failure details
  errorMessage          String
  errorType             String?
  stackTrace            String?
  logSnippet            String?

  // Temporal data
  occurredAt            DateTime         @default(now())
  environment           String?
  buildNumber           String?
  commitSha             String?
  branch                String?

  // RCA Documentation
  rootCause             String?
  detailedAnalysis      String?
  solution              String?
  preventionSteps       String?
  workaround            String?

  // Resolution tracking
  status                String           @default("NEW") // NEW | INVESTIGATING | DOCUMENTED | RESOLVED | RECURRING
  resolvedAt            DateTime?
  resolvedBy            String?
  timeToResolve         Int?

  // Integration links
  jiraIssueId           String?
  jiraIssueKey          String?
  prUrl                 String?

  // Pattern detection
  isRecurring           Boolean          @default(false)
  firstSeenAt           DateTime         @default(now())
  lastSeenAt            DateTime         @default(now())
  occurrenceCount       Int              @default(1)
  recurrencePattern     String?

  // Metadata
  severity              String           @default("MEDIUM") // CRITICAL | HIGH | MEDIUM | LOW
  isKnownIssue          Boolean          @default(false)

  // Relations
  jiraIssue             JiraIssue?       @relation(fields: [jiraIssueId], references: [id])
  jiraIssueId           String?

  // Timestamps
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([failureSignature])
  @@index([testName])
  @@index([occurredAt])
  @@index([status])
}

// Simplified AI usage tracking for demo
model AIUsage {
  id              String   @id @default(uuid())
  provider        String   // "anthropic", "openai", "google"
  model           String
  tokens          Int
  cost            Float
  cacheHit        Boolean  @default(false)
  responseTimeMs  Int
  createdAt       DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
}

// Jira integration models (optional for demo)
model JiraConfig {
  id            String    @id @default(uuid())
  baseUrl       String
  apiToken      String
  projectKey    String
  defaultType   String    @default("BUG") // BUG | TASK | STORY
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JiraIssue {
  id              String            @id @default(uuid())
  issueKey        String            @unique
  issueType       String            // BUG | TASK | STORY
  status          String            @default("TODO") // TODO | IN_PROGRESS | DONE
  summary         String
  description     String?
  labels          String
  pipelineId      String?
  testRunId       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  failureArchives FailureArchive[]

  @@index([issueKey])
}

// Pipeline model (stub for demo)
model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
