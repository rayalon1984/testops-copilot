// Production PostgreSQL Schema
// This schema uses PostgreSQL with proper enums and features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid()) @db.Uuid
  email          String        @unique
  password       String
  firstName      String?
  lastName       String?
  role           UserRole      @default(USER)
  autonomyLevel         AutonomyLevel @default(balanced)
  pinnedStarterPrompts  String?
  settings              Json?         @default("{}")
  createdAt             DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  notifications    Notification[]
  testRuns         TestRun[]
  chatSessions     ChatSession[]
  pendingActions   PendingAction[]
  auditLogs        AuditLog[]

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

enum AutonomyLevel {
  conservative
  balanced
  autonomous
}

model TestRun {
  id         String   @id @default(uuid()) @db.Uuid
  pipelineId String   @db.Uuid
  userId     String?   @db.Uuid
  name       String
  status     TestStatus
  startedAt  DateTime @default(now())
  completedAt DateTime?
  duration   Int?
  totalTests Int      @default(0)
  passed     Int      @default(0)
  failed     Int      @default(0)
  skipped    Int      @default(0)
  flaky      Int      @default(0)
  branch     String?
  commit     String?
  buildNumber String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user        User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipeline    Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  results     TestResult[]
  notifications Notification[]
  xraySyncs   XraySync[]

  @@index([userId])
  @@index([pipelineId])
  @@index([status])
  @@index([startedAt])
  @@map("test_runs")
}

enum TestStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
  FLAKY
}

model Pipeline {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  type        PipelineType
  repository  String?
  branch      String?
  config      Json?
  enabled     Boolean      @default(true)
  lastRunAt   DateTime?
  teamId      String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  testRuns    TestRun[]
  team        Team?        @relation(fields: [teamId], references: [id])

  @@index([teamId])
  @@map("pipelines")
}

enum PipelineType {
  GITHUB_ACTIONS
  JENKINS
  CUSTOM
}

model TestResult {
  id                 String     @id @default(uuid()) @db.Uuid
  testRunId          String     @db.Uuid
  name               String
  className          String?
  status             TestStatus
  duration           Int?
  error              String?
  stackTrace         String?
  externalTestCaseId String?    // e.g., "PROJ-TC-123" (Xray) or "C12345" (TestRail)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  testRun     TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@index([testRunId])
  @@index([status])
  @@map("test_results")
}

model Notification {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  testRunId String?           @db.Uuid
  type      NotificationType
  title     String
  message   String
  read      Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  testRun   TestRun?          @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

enum NotificationType {
  TEST_FAILED
  TEST_PASSED
  PIPELINE_FAILED
  PIPELINE_PASSED
  SYSTEM
}

model FailureArchive {
  id              String    @id @default(uuid()) @db.Uuid
  testName        String
  errorMessage    String
  stackTrace      String?
  category        String?
  severity        String?
  rcaDocumented   Boolean   @default(false)
  rootCause       String?
  solution        String?
  prevention      String?
  relatedJiraIssue String?
  tags            String?   // Comma-separated string for compatibility
  metadata        Json?
  firstOccurrence DateTime  @default(now())
  lastOccurrence  DateTime  @default(now())
  occurrenceCount Int       @default(1)
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?
  rcaVersion      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  revisions       RCARevision[]
  comments        FailureComment[]

  @@index([testName])
  @@index([category])
  @@index([resolved])
  @@map("failure_archive")
}

model RCARevision {
  id               String   @id @default(uuid()) @db.Uuid
  failureArchiveId String   @db.Uuid
  version          Int
  rootCause        String?
  solution         String?
  prevention       String?
  tags             String?
  editedBy         String
  editSummary      String?
  createdAt        DateTime @default(now())

  failureArchive   FailureArchive @relation(fields: [failureArchiveId], references: [id], onDelete: Cascade)

  @@index([failureArchiveId])
  @@map("rca_revisions")
}

model FailureComment {
  id               String   @id @default(uuid()) @db.Uuid
  failureArchiveId String   @db.Uuid
  userId           String
  content          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  failureArchive   FailureArchive @relation(fields: [failureArchiveId], references: [id], onDelete: Cascade)

  @@index([failureArchiveId])
  @@index([userId])
  @@map("failure_comments")
}

model FailurePattern {
  id                    String    @id @default(uuid()) @db.Uuid
  signature             String    @unique
  patternName           String
  description           String
  affectedTests         String?
  commonRootCause       String?
  matchCount            Int       @default(0)
  lastMatched           DateTime  @default(now())
  recurrenceRule        String?
  confidence            Float     @default(0.0)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([signature])
  @@index([isActive])
  @@map("failure_patterns")
}

model AIUsage {
  id            String   @id @default(uuid()) @db.Uuid
  provider      String
  model         String
  feature       String
  promptTokens  Int
  completionTokens Int
  totalTokens   Int
  cost          Float
  userId        String?  @db.Uuid
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([provider])
  @@index([feature])
  @@index([createdAt])
  @@map("ai_usage")
}

model JiraConfig {
  id            String    @id @default(uuid()) @db.Uuid
  baseUrl       String
  apiToken      String
  projectKey    String
  defaultType   String    @default("BUG")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("jira_config")
}

model JiraIssue {
  id              String    @id @default(uuid()) @db.Uuid
  jiraKey         String    @unique
  jiraId          String
  projectKey      String
  summary         String
  description     String?
  issueType       String
  status          String
  priority        String?
  assignee        String?
  reporter        String?
  testRunId       String?   @db.Uuid
  failureArchiveId String?  @db.Uuid
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([jiraKey])
  @@index([projectKey])
  @@index([testRunId])
  @@index([failureArchiveId])
  @@map("jira_issues")
}

model ConfluencePage {
  id              String    @id @default(uuid()) @db.Uuid
  pageId          String    @unique
  spaceKey        String
  title           String
  url             String
  failureArchiveId String?  @db.Uuid
  publishedBy     String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([spaceKey])
  @@map("confluence_pages")
}

model TestRailRun {
  id              String    @id @default(uuid()) @db.Uuid
  testRailRunId   Int       @unique
  projectId       Int
  suiteId         Int?
  name            String
  description     String?
  testRunId       String?   @db.Uuid
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
  @@map("testrail_runs")
}

// ─── AI Copilot Chat Persistence ───

model ChatSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  title          String   @default("New Chat")
  activePersona  String?  // Last persona used in this session
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
  pendingActions PendingAction[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @db.Uuid
  role      String   // user | assistant | tool_start | tool_result | thinking | error
  content   String
  toolName  String?
  persona   String?  // Which virtual team persona generated this message
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ─── AI Copilot Confirmation System ───

model PendingAction {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @db.Uuid
  userId     String   @db.Uuid
  toolName   String
  parameters String   // JSON-serialized tool parameters
  status     String   @default("PENDING") // PENDING | APPROVED | DENIED | EXPIRED
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@map("pending_actions")
}

// ─── In-App AI Provider Configuration ───

model AIProviderConfig {
  id          String   @id @default("singleton")
  provider    String   @default("mock") // anthropic | openai | google | azure | openrouter | mock
  model       String   @default("mock-model")
  apiKey      String?  // AES-256-GCM encrypted
  extraConfig String?  // JSON: azure endpoint, openrouter app name, etc.
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("ai_provider_config")
}

// ─── Team Workspaces ───

model Team {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  slug        String          @unique
  description String?
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  members     TeamMember[]
  pipelines   Pipeline[]
  dashboards  DashboardConfig[]

  @@index([slug])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(uuid()) @db.Uuid
  teamId   String   @db.Uuid
  userId   String
  role     String   @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER
  joinedAt DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model DashboardConfig {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String?  @db.Uuid
  userId    String
  name      String
  layout    String   // JSON widget config
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([userId])
  @@map("dashboard_configs")
}

// ─── Shareable Analysis Links ───

model SharedAnalysis {
  id          String   @id @default(uuid()) @db.Uuid
  token       String   @unique
  userId      String
  sessionId   String?
  title       String
  content     String
  persona     String?
  toolSummary String?  // JSON
  expiresAt   DateTime
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("shared_analyses")
}

// ─── Multi-Channel User Mapping ───

model ChannelUserMapping {
  id         String   @id @default(uuid()) @db.Uuid
  channel    String   // 'slack' | 'teams'
  externalId String   // Slack user ID or Teams user ID
  userId     String   // Internal TestOps user ID
  metadata   String?  // JSON: team/channel context
  createdAt  DateTime @default(now())

  @@unique([channel, externalId])
  @@index([userId])
  @@map("channel_user_mappings")
}

// ─── Audit Logging ───

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String
  entityId   String
  userId     String   @db.Uuid
  metadata   String?  // JSON
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Self-Healing Pipelines ───

model HealingRule {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  description         String
  pattern             String
  patternType         String   @default("regex")   // regex | keyword | signature
  category            String   @default("transient") // transient | infrastructure | flaky | custom
  action              String   @default("retry")    // retry | quarantine | fix_pr | notify
  maxRetries          Int      @default(2)
  cooldownMinutes     Int      @default(60)
  confidenceThreshold Float    @default(0.9)
  enabled             Boolean  @default(true)
  isBuiltIn           Boolean  @default(false)
  priority            Int      @default(50)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  events HealingEvent[]

  @@index([enabled, action])
  @@index([priority])
  @@map("healing_rules")
}

model HealingEvent {
  id              String    @id @default(uuid()) @db.Uuid
  ruleId          String?   @db.Uuid
  testRunId       String
  pipelineId      String
  action          String
  status          String    @default("pending") // pending | executing | success | failed | skipped
  matchConfidence Float
  matchReason     String
  errorMessage    String?
  retriedRunId    String?
  metadata        String?   // JSON
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  rule HealingRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([testRunId])
  @@index([pipelineId, createdAt])
  @@index([status])
  @@map("healing_events")
}

model QuarantinedTest {
  id              String   @id @default(uuid()) @db.Uuid
  testName        String   @unique
  reason          String
  severity        String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  quarantinedBy   String   @default("auto")
  healingEventId  String?
  flakinessScore  Float    @default(0)
  occurrenceCount Int      @default(1)
  status          String   @default("quarantined") // quarantined | reinstated
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([testName])
  @@map("quarantined_tests")
}

// ─── Xray Cloud Integration ───

model XraySync {
  id              String    @id @default(uuid()) @db.Uuid
  testRunId       String    @db.Uuid             // FK to TestRun
  xrayExecutionId String?                        // Xray Test Execution issue key (e.g., "PROJ-456")
  projectKey      String                         // Jira project key
  status          String    @default("PENDING")  // PENDING | SYNCING | SYNCED | FAILED
  trigger         String    @default("MANUAL")   // MANUAL | AUTO
  resultCount     Int       @default(0)          // Number of results pushed
  errorMessage    String?                        // Last error if FAILED
  syncedAt        DateTime?                      // When sync completed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  testRun         TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@index([testRunId])
  @@index([status])
  @@map("xray_syncs")
}

// ─── Smart Test Selection (Phase 3) ───

model TestCoverageMap {
  id            String   @id @default(uuid()) @db.Uuid
  testName      String
  sourceFile    String
  coveredLines  String   // JSON array of line ranges: [[1,50],[80,120]]
  pipelineId    String?  @db.Uuid
  branch        String?
  collectedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([testName, sourceFile])
  @@index([sourceFile])
  @@index([testName])
  @@map("test_coverage_maps")
}

model DependencyEdge {
  id            String   @id @default(uuid()) @db.Uuid
  sourceFile    String   // The file that imports
  targetFile    String   // The file being imported
  importType    String   @default("static") // static | dynamic | re-export
  pipelineId    String?  @db.Uuid
  collectedAt   DateTime @default(now())

  @@unique([sourceFile, targetFile])
  @@index([targetFile])
  @@index([sourceFile])
  @@map("dependency_edges")
}

model SelectionAccuracy {
  id              String   @id @default(uuid()) @db.Uuid
  testRunId       String?  @db.Uuid
  pipelineId      String?  @db.Uuid
  totalSelected   Int
  truePositives   Int      @default(0)
  falseNegatives  Int      @default(0)
  falsePositives  Int      @default(0)
  precision       Float    @default(0)
  recall          Float    @default(0)
  strategyUsed    String   // convention | dependency | coverage | correlation | mixed
  changedFiles    String?  // JSON array of changed files
  createdAt       DateTime @default(now())

  @@index([pipelineId])
  @@index([createdAt])
  @@index([strategyUsed])
  @@map("selection_accuracies")
}

model RegressionEvent {
  id                String    @id @default(uuid()) @db.Uuid
  testName          String
  pipelineId        String    @db.Uuid
  introducingCommit String?
  introducingPR     Int?
  prTitle           String?
  prAuthor          String?
  testRunId         String    @db.Uuid
  lastPassingCommit String?
  severity          String    @default("MEDIUM") // CRITICAL | HIGH | MEDIUM | LOW
  status            String    @default("detected") // detected | confirmed | resolved | false_positive
  errorMessage      String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([testName])
  @@index([pipelineId])
  @@index([status])
  @@index([createdAt])
  @@map("regression_events")
}
