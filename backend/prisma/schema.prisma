// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum PipelineType {
  JENKINS
  GITHUB_ACTIONS
  CUSTOM
}

enum PipelineStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
  TIMEOUT
}

enum TestStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
  ERROR
}

enum TestResult {
  PASS
  FAIL
  SKIP
  ERROR
}

enum NotificationType {
  EMAIL
  SLACK
  PUSHOVER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum JiraIssueType {
  BUG
  TASK
  STORY
  EPIC
}

enum JiraIssueStatus {
  TODO
  IN_PROGRESS
  DONE
  CUSTOM
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String?
  lastName      String?
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pipelines     Pipeline[]
  testRuns      TestRun[]
  notifications Notification[]
}

model Pipeline {
  id            String         @id @default(uuid())
  name          String
  type          PipelineType
  config        Json
  status        PipelineStatus @default(PENDING)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  testRuns      TestRun[]
  jiraIssues    JiraIssue[]
}

model TestRun {
  id            String         @id @default(uuid())
  pipelineId    String
  userId        String
  status        TestStatus     @default(PENDING)
  branch        String?
  commit        String?
  startTime     DateTime?
  endTime       DateTime?
  duration      Int?
  results       Json?
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pipeline      Pipeline       @relation(fields: [pipelineId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  testCases     TestCase[]
  jiraIssues    JiraIssue[]
}

model TestCase {
  id            String      @id @default(uuid())
  testRunId     String
  name          String
  status        TestStatus  @default(PENDING)
  duration      Int?
  error         String?
  stackTrace    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  testRun       TestRun     @relation(fields: [testRunId], references: [id])
}

model Notification {
  id            String             @id @default(uuid())
  userId        String
  type          NotificationType
  status        NotificationStatus @default(PENDING)
  content       Json
  error         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id])
}

model JiraConfig {
  id            String    @id @default(uuid())
  baseUrl       String
  apiToken      String
  projectKey    String
  defaultType   JiraIssueType @default(BUG)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JiraIssue {
  id            String    @id @default(uuid())
  issueKey      String    @unique
  issueType     JiraIssueType
  status        JiraIssueStatus @default(TODO)
  summary       String
  description   String?
  labels        String[]
  pipelineId    String?
  testRunId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  pipeline      Pipeline? @relation(fields: [pipelineId], references: [id])
  testRun       TestRun?  @relation(fields: [testRunId], references: [id])

  @@index([issueKey])
}