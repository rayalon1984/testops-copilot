// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  pipelines     Pipeline[]
  testRuns      TestRun[]
  notifications Notification[]
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

model Pipeline {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        PipelineType
  config      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [userId], references: [id])
  userId      String
  testRuns    TestRun[]
  status      PipelineStatus @default(ACTIVE)
}

enum PipelineType {
  JENKINS
  GITHUB_ACTIONS
  GITLAB_CI
  CUSTOM
}

enum PipelineStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model TestRun {
  id          String    @id @default(uuid())
  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id])
  pipelineId  String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  status      TestStatus
  result      TestResult?
  logs        String?
  metadata    Json?
  createdBy   User      @relation(fields: [userId], references: [id])
  userId      String
  testCases   TestCase[]
}

enum TestStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TestResult {
  PASSED
  FAILED
  FLAKY
  SKIPPED
  BLOCKED
}

model TestCase {
  id          String    @id @default(uuid())
  name        String
  description String?
  testRun     TestRun   @relation(fields: [testRunId], references: [id])
  testRunId   String
  status      TestStatus
  result      TestResult?
  duration    Int?      // in milliseconds
  errorMessage String?
  stackTrace   String?
  metadata     Json?
}

model Notification {
  id        String    @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  status    NotificationStatus @default(UNREAD)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  metadata  Json?
}

enum NotificationType {
  PIPELINE_STATUS
  TEST_FAILURE
  SYSTEM_ALERT
  MAINTENANCE
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}