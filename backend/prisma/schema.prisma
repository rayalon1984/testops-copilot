// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum PipelineType {
  JENKINS
  GITHUB_ACTIONS
  CUSTOM
}

enum PipelineStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILURE
  CANCELLED
  TIMEOUT
}

enum TestStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
  ERROR
}

enum TestResult {
  PASS
  FAIL
  SKIP
  ERROR
}

enum NotificationType {
  EMAIL
  SLACK
  PUSHOVER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum JiraIssueType {
  BUG
  TASK
  STORY
  EPIC
}

enum JiraIssueStatus {
  TODO
  IN_PROGRESS
  DONE
  CUSTOM
}

enum FailureStatus {
  NEW
  INVESTIGATING
  DOCUMENTED
  RESOLVED
  RECURRING
}

enum FailureSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String?
  lastName      String?
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pipelines     Pipeline[]
  testRuns      TestRun[]
  notifications Notification[]
}

model Pipeline {
  id            String         @id @default(uuid())
  name          String
  type          PipelineType
  config        Json
  status        PipelineStatus @default(PENDING)
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  testRuns      TestRun[]
  jiraIssues    JiraIssue[]
}

model TestRun {
  id            String         @id @default(uuid())
  pipelineId    String
  userId        String
  status        TestStatus     @default(PENDING)
  branch        String?
  commit        String?
  startTime     DateTime?
  endTime       DateTime?
  duration      Int?
  results       Json?
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pipeline      Pipeline       @relation(fields: [pipelineId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  testCases     TestCase[]
  jiraIssues    JiraIssue[]
}

model TestCase {
  id            String      @id @default(uuid())
  testRunId     String
  name          String
  status        TestStatus  @default(PENDING)
  duration      Int?
  error         String?
  stackTrace    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  testRun       TestRun     @relation(fields: [testRunId], references: [id])
}

model Notification {
  id            String             @id @default(uuid())
  userId        String
  type          NotificationType
  status        NotificationStatus @default(PENDING)
  content       Json
  error         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id])
}

model JiraConfig {
  id            String    @id @default(uuid())
  baseUrl       String
  apiToken      String
  projectKey    String
  defaultType   JiraIssueType @default(BUG)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JiraIssue {
  id            String    @id @default(uuid())
  issueKey      String    @unique
  issueType     JiraIssueType
  status        JiraIssueStatus @default(TODO)
  summary       String
  description   String?
  labels        String[]
  pipelineId    String?
  testRunId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pipeline      Pipeline? @relation(fields: [pipelineId], references: [id])
  testRun       TestRun?  @relation(fields: [testRunId], references: [id])
  failureArchives FailureArchive[]

  @@index([issueKey])
}

model FailureArchive {
  id                    String           @id @default(uuid())
  testRunId             String
  testCaseId            String?
  testName              String
  failureSignature      String           // Smart hash for pattern matching

  // Failure details
  errorMessage          String           @db.Text
  errorType             String?
  stackTrace            String?          @db.Text
  logSnippet            String?          @db.Text
  screenshots           String[]         @default([])

  // Temporal data
  occurredAt            DateTime         @default(now())
  environment           String?
  buildNumber           String?
  commitSha             String?
  branch                String?

  // RCA Documentation (the gold!)
  rootCause             String?          @db.Text
  detailedAnalysis      String?          @db.Text
  solution              String?          @db.Text
  preventionSteps       String?          @db.Text
  workaround            String?          @db.Text
  relatedDocumentation  String[]         @default([])

  // Resolution tracking
  status                FailureStatus    @default(NEW)
  resolvedAt            DateTime?
  resolvedBy            String?
  timeToResolve         Int?             // in minutes

  // Integration links
  jiraIssueId           String?
  jiraIssueKey          String?
  prUrl                 String?

  // Pattern detection
  isRecurring           Boolean          @default(false)
  firstSeenAt           DateTime         @default(now())
  lastSeenAt            DateTime         @default(now())
  occurrenceCount       Int              @default(1)
  recurrencePattern     String?

  // Metadata
  tags                  String[]         @default([])
  severity              FailureSeverity  @default(MEDIUM)
  isKnownIssue          Boolean          @default(false)

  // Timestamps
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Relations
  jiraIssue             JiraIssue?       @relation(fields: [jiraIssueId], references: [id])
  relatedFailures       FailureArchive[] @relation("RelatedFailures")
  relatedTo             FailureArchive[] @relation("RelatedFailures")

  @@index([failureSignature])
  @@index([testName])
  @@index([occurredAt])
  @@index([status])
  @@index([isRecurring])
}

model FailurePattern {
  id                    String    @id @default(uuid())
  signature             String    @unique
  patternName           String
  description           String    @db.Text
  affectedTests         String[]
  commonRootCause       String?   @db.Text
  matchCount            Int       @default(0)
  lastMatched           DateTime  @default(now())
  recurrenceRule        String?   // e.g., "Every Friday 5pm"
  confidence            Float     @default(0.0)

  // Metadata
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([signature])
  @@index([isActive])
}

// TestRail Integration Models
model TestRailConfig {
  id            String    @id @default(uuid())
  baseUrl       String
  username      String
  apiKey        String
  projectId     Int?
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TestRailRun {
  id              String    @id @default(uuid())
  testRunId       String    @unique    // Our internal test run ID
  testRailRunId   Int                  // TestRail's run ID
  projectId       Int
  suiteId         Int
  name            String
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([testRunId])
  @@index([testRailRunId])
}

model TestRailSync {
  id              String    @id @default(uuid())
  testRunId       String
  testRailRunId   Int
  syncedAt        DateTime  @default(now())
  status          String    // 'success', 'failed', 'partial'
  resultCount     Int       @default(0)
  error           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([testRunId])
  @@index([syncedAt])
}