// SQLite Development Schema for Demo Mode
// This is a simplified version using SQLite instead of PostgreSQL
// Note: SQLite doesn't support enums, so we use String with validation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      String   @default("USER") // ADMIN | USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  notifications Notification[]
  testRuns      TestRun[]
}

model TestRun {
  id         String    @id @default(uuid())
  pipelineId String
  userId     String
  name       String
  status     String    @default("PENDING") // PENDING | RUNNING | PASSED | FAILED | SKIPPED | ERROR
  branch     String?
  commit     String?
  startTime  DateTime?
  endTime    DateTime?
  duration   Int?
  results    String?   // JSON stored as string
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  testResults TestResult[]

  @@index([pipelineId])
  @@index([userId])
  @@index([status])
}

model FailureArchive {
  id                    String           @id @default(uuid())
  testRunId             String
  testCaseId            String?
  testName              String
  failureSignature      String

  // Failure details
  errorMessage          String
  errorType             String?
  stackTrace            String?
  logSnippet            String?
  screenshots           String?           // Comma-separated URLs (SQLite doesn't support arrays)

  // Temporal data
  occurredAt            DateTime         @default(now())
  environment           String?
  buildNumber           String?
  commitSha             String?
  branch                String?

  // RCA Documentation
  rootCause             String?
  detailedAnalysis      String?
  solution              String?
  preventionSteps       String?
  workaround            String?

  // Resolution tracking
  status                String           @default("NEW") // NEW | INVESTIGATING | DOCUMENTED | RESOLVED | RECURRING
  resolvedAt            DateTime?
  resolvedBy            String?
  timeToResolve         Int?

  // Integration links
  jiraIssueId           String?
  jiraIssueKey          String?
  prUrl                 String?

  // Pattern detection
  isRecurring           Boolean          @default(false)
  firstSeenAt           DateTime         @default(now())
  lastSeenAt            DateTime         @default(now())
  occurrenceCount       Int              @default(1)
  recurrencePattern     String?

  // Metadata
  severity              String?          @default("MEDIUM") // CRITICAL | HIGH | MEDIUM | LOW
  isKnownIssue          Boolean          @default(false)
  tags                  String?          // Comma-separated tags (SQLite doesn't support arrays)
  relatedDocumentation  String?          // Comma-separated URLs (SQLite doesn't support arrays)

  // Relations
  jiraIssue             JiraIssue?       @relation(fields: [jiraIssueId], references: [id])

  // Timestamps
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([failureSignature])
  @@index([testName])
  @@index([occurredAt])
  @@index([status])
}

// Simplified AI usage tracking for demo
model AIUsage {
  id              String   @id @default(uuid())
  provider        String   // "anthropic", "openai", "google"
  model           String
  tokens          Int
  cost            Float
  cacheHit        Boolean  @default(false)
  responseTimeMs  Int
  createdAt       DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
}

// Jira integration models (optional for demo)
model JiraConfig {
  id            String    @id @default(uuid())
  baseUrl       String
  apiToken      String
  projectKey    String
  defaultType   String    @default("BUG") // BUG | TASK | STORY
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model JiraIssue {
  id              String            @id @default(uuid())
  issueKey        String            @unique
  issueType       String            // BUG | TASK | STORY
  status          String            @default("TODO") // TODO | IN_PROGRESS | DONE
  summary         String
  description     String?
  labels          String?           // Comma-separated string (SQLite doesn't support arrays)
  pipelineId      String?
  testRunId       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  failureArchives FailureArchive[]

  @@index([issueKey])
}

// Pipeline model
model Pipeline {
  id          String     @id @default(uuid())
  name        String
  type        String     @default("CUSTOM") // JENKINS | GITHUB_ACTIONS | CUSTOM
  status      String     @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILURE | CANCELLED | TIMEOUT
  config      String     // JSON stored as string
  description String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  testRuns    TestRun[]

  @@index([userId])
  @@index([type])
  @@index([status])
}

// Failure pattern detection
model FailurePattern {
  id                    String    @id @default(uuid())
  signature             String    @unique
  patternName           String
  description           String
  affectedTests         String?   // Comma-separated test names (SQLite doesn't support arrays)
  commonRootCause       String?
  matchCount            Int       @default(0)
  lastMatched           DateTime  @default(now())
  recurrenceRule        String?
  confidence            Float     @default(0.0)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([signature])
  @@index([isActive])
}

// Added during Refactor for missing models

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?  // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model TestRailRun {
  id          String   @id @default(uuid())
  testRunId   String   @unique
  runId       Int      // TestRail Run ID
  projectId   Int
  suiteId     Int
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConfluencePage {
  id          String   @id @default(uuid())
  pageId      String
  title       String
  spaceKey    String
  version     Int
  url         String
  testRunId   String?
  type        String?
  sourceId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TestResult {
  id          String   @id @default(uuid())
  testRunId   String
  testName    String
  testCaseId  String?
  message     String?
  status      String
  duration    Int?
  error       String?
  stackTrace  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  testRun     TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  @@index([testRunId])
}
