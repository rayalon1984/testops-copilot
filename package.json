{
  "name": "testops-companion",
  "version": "1.0.0",
  "description": "A comprehensive test automation management platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "npm install --legacy-peer-deps && npm run setup:frontend && npm run setup:backend && npm run security:fix",
    "setup:frontend": "cd frontend && npm install --legacy-peer-deps",
    "setup:backend": "cd backend && npm install",
    "dev": "docker-compose up -d",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "clean": "rimraf node_modules frontend/node_modules backend/node_modules",
    "db:migrate": "cd backend && npm run migrate:dev",
    "db:seed": "cd backend && npm run seed",
    "generate:types": "cd backend && npm run generate:types",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "deploy": "bash scripts/deploy.sh",
    "security:audit": "npm audit && cd frontend && npm audit && cd ../backend && npm audit",
    "security:fix": "npm audit fix --legacy-peer-deps && cd frontend && npm audit fix --legacy-peer-deps && cd ../backend && npm audit fix",
    "update:deps": "npm run update:deps:root && npm run update:deps:frontend && npm run update:deps:backend",
    "update:deps:root": "npm update --legacy-peer-deps",
    "update:deps:frontend": "cd frontend && npm update --legacy-peer-deps",
    "update:deps:backend": "cd backend && npm update",
    "postinstall": "npm run generate:types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayalon1984/testops-companion.git"
  },
  "keywords": [
    "testops",
    "automation",
    "testing",
    "qa",
    "devops",
    "ci/cd"
  ],
  "author": "Rotem Ayalon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rayalon1984/testops-companion/issues"
  },
  "homepage": "https://github.com/rayalon1984/testops-companion#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.1"
  }
}