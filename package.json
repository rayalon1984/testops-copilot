{
  "name": "testops-companion",
  "version": "2.8.1",
  "description": "A comprehensive test operations companion for managing test pipelines and results",
  "main": "index.js",
  "scripts": {
    "postinstall": "npm run install:backend && npm run install:frontend && npm run install:mcp",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:simple": "concurrently \"npm run dev:simple:backend\" \"npm run dev:frontend\" \"npm run dev:browser\"",
    "dev:simple:backend": "cd backend && npm run dev:simple",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:browser": "node scripts/open-browser.js http://localhost:5173 8000",
    "local:setup": "bash scripts/local-setup.sh",
    "local:start": "docker-compose up -d db redis weaviate && echo 'Services started! Run: npm run dev'",
    "local:stop": "docker-compose down",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm run start",
    "start:frontend": "cd frontend && npm run start",
    "build": "concurrently \"npm run build:backend\" \"npm run build:frontend\" \"npm run build:mcp\"",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:mcp": "cd mcp-server && npm run build",
    "test": "concurrently \"npm run test:backend\" \"npm run test:frontend\"",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "setup": "npm run setup:clean && npm run setup:install && npm run setup:env && npm run setup:db",
    "setup:clean": "rimraf node_modules frontend/node_modules backend/node_modules mcp-server/node_modules",
    "setup:install": "npm install && concurrently \"npm run install:backend\" \"npm run install:frontend\" \"npm run install:mcp\"",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "install:mcp": "cd mcp-server && npm install",
    "setup:env": "node scripts/setup-env.js",
    "setup:db": "cd backend && npm run db:setup",
    "lint": "concurrently \"npm run lint:backend\" \"npm run lint:frontend\"",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "typecheck": "concurrently \"npm run typecheck:backend\" \"npm run typecheck:frontend\" \"npm run typecheck:mcp\"",
    "typecheck:backend": "cd backend && npm run typecheck",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "typecheck:mcp": "cd mcp-server && npm run typecheck",
    "validate": "npm run validate:env && npm run validate:schema",
    "validate:env": "node scripts/validate-env.js",
    "validate:schema": "node scripts/validate-schema.js",
    "mcp:dev": "cd mcp-server && npm run dev",
    "mcp:inspector": "cd mcp-server && npm run inspector",
    "mcp:build": "cd mcp-server && npm run build"
  },
  "keywords": [
    "test",
    "operations",
    "pipeline",
    "ci",
    "cd",
    "test-results",
    "dashboard"
  ],
  "author": "Rotem Ayalon",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@azure/openai": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "bull": "^4.16.5",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "ioredis": "^5.8.2",
    "js-yaml": "^4.1.1",
    "openai": "^6.9.1",
    "p-queue": "^9.0.1",
    "p-retry": "^7.1.0",
    "rimraf": "^5.0.5",
    "weaviate-ts-client": "^2.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.9",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "eslint": "^8.56.0"
  }
}
