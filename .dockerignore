**/__tests__
**/*.test.*
**/*.spec.*

# Production
**/build
**/dist
**/.next
**/.nuxt
**/.docusaurus

# Development
**/.env
**/.env.*
!**/.env.example
**/.vscode
**/.idea
**/.DS_Store
**/*.log
**/logs
