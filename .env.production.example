# TestOps Copilot — Production Environment Variables
#
# SETUP:
#   Quick deploy (auto-generates secrets):
#     ./scripts/deploy-prod.sh
#
#   Manual deploy:
#     1. cp .env.production.example .env.production
#     2. Fill in the REQUIRED section (everything else is optional)
#     3. Run: ./scripts/preflight-check.sh  (validates before deploy)
#     4. Run: docker compose -f docker-compose.prod.yml up -d
#
# IMPORTANT: Never commit .env.production to version control!
#
# Generate secure secrets with:
#   openssl rand -hex 32

# =============================================================================
# REQUIRED — Deploy will fail without these
# =============================================================================

# Database connection (composed from POSTGRES_* vars below — do not edit manually)
# DATABASE_URL is built automatically by docker-compose.prod.yml

# Database (PostgreSQL)
POSTGRES_USER=testops
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=testops

# JWT — MUST be ≥32 characters each
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Session & CSRF — ≥32 characters each
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32
CSRF_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Cookie security — set to false if NOT using HTTPS (e.g., internal HTTP deployment)
SECURE_COOKIE=false

# =============================================================================
# SERVER — Adjust for your environment
# =============================================================================

NODE_ENV=production
PORT=3000
LOG_LEVEL=info
BCRYPT_SALT_ROUNDS=12

# Default admin account (created on first deploy if no users exist)
ADMIN_EMAIL=admin@testops.local
ADMIN_PASSWORD=CHANGE_ME_min_8_chars

# Your deployment URL — for HTTP on internal network, use the machine's IP/hostname
# Examples:
#   CORS_ORIGIN=http://20.20.21.42
#   CORS_ORIGIN=https://testops.yourcompany.com
CORS_ORIGIN=http://localhost
VITE_API_URL=http://localhost/api

# Rate limiting (15-minute window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis — required for production sessions and caching
# The docker-compose overrides REDIS_HOST/PORT, but set REDIS_ENABLED here
REDIS_ENABLED=true

# =============================================================================
# OPTIONAL: AI PROVIDERS (enable at least one for AI features)
# =============================================================================

# AI_ENABLED=true
# AI_PROVIDER=anthropic     # anthropic | openai | google | azure | bedrock

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google (Gemini)
# GOOGLE_AI_API_KEY=...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# AWS Bedrock — on EC2 with IAM role: just set the region, credentials are automatic.
# Outside AWS: provide explicit access key + secret.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=eu-west-1

# AI budget cap (USD per month, 0 = unlimited)
# AI_MONTHLY_BUDGET_USD=100

# Vector database for semantic search (runs in docker-compose)
# WEAVIATE_URL=http://weaviate:8080
# WEAVIATE_API_KEY=GENERATE_A_SECURE_API_KEY_HERE

# =============================================================================
# OPTIONAL: INTEGRATIONS
# =============================================================================

# ── Jira (Atlassian Cloud) ──
# All 4 vars required to enable. Uses Basic auth (email + API token).
# Generate token at: https://id.atlassian.net/manage-profile/security/api-tokens
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-atlassian-api-token
# JIRA_PROJECT_KEY=PROJ
# JIRA_DEFAULT_ISSUE_TYPE=Bug

# ── GitHub ──
# GITHUB_TOKEN=ghp_...
# GITHUB_WEBHOOK_SECRET=...

# ── TestRail ──
# TESTRAIL_BASE_URL=https://your-company.testrail.io
# TESTRAIL_USERNAME=...
# TESTRAIL_API_KEY=...
# TESTRAIL_PROJECT_ID=1

# ── Confluence ──
# CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki
# CONFLUENCE_USERNAME=...
# CONFLUENCE_API_TOKEN=...
# CONFLUENCE_SPACE_KEY=TEST

# =============================================================================
# OPTIONAL: NOTIFICATIONS
# =============================================================================

# Slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL=#testops-alerts

# Email (SMTP)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=...
# EMAIL_PASSWORD=...
# EMAIL_FROM=testops@your-company.com

# Pushover
# PUSHOVER_USER_KEY=...
# PUSHOVER_APP_TOKEN=...
