# TestOps Companion - Production Environment Variables
# Copy this file to .env.production and fill in your values
#
# IMPORTANT: Never commit .env.production to version control!
#
# To generate secure random secrets, use:
#   openssl rand -base64 48
# or:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Database (PostgreSQL) - MUST change default credentials
POSTGRES_USER=testops
POSTGRES_PASSWORD=GENERATE_A_SECURE_PASSWORD_HERE
POSTGRES_DB=testops
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# JWT Authentication - MUST be at least 32 characters each
JWT_SECRET=GENERATE_A_64_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_64_CHAR_SECRET_HERE
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://your-domain.com
VITE_API_URL=https://your-domain.com/api
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_SALT_ROUNDS=12

# =============================================================================
# OPTIONAL: VECTOR DATABASE (Weaviate)
# =============================================================================

# Weaviate API Key for authenticated access (required if AI features enabled)
# WEAVIATE_API_KEY=GENERATE_A_SECURE_API_KEY_HERE
# WEAVIATE_URL=http://weaviate:8080

# =============================================================================
# OPTIONAL: AI PROVIDERS (enable at least one for AI features)
# =============================================================================

# AI_ENABLED=true
# AI_PROVIDER=anthropic

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4)
# OPENAI_API_KEY=sk-...

# Google (Gemini)
# GOOGLE_AI_API_KEY=...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# =============================================================================
# OPTIONAL: INTEGRATIONS
# =============================================================================

# GitHub
# GITHUB_TOKEN=ghp_...
# GITHUB_WEBHOOK_SECRET=...

# Jira
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_API_TOKEN=...
# JIRA_PROJECT_KEY=TEST

# TestRail
# TESTRAIL_BASE_URL=https://your-company.testrail.io
# TESTRAIL_USERNAME=...
# TESTRAIL_API_KEY=...
# TESTRAIL_PROJECT_ID=1

# Confluence
# CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki
# CONFLUENCE_USERNAME=...
# CONFLUENCE_API_TOKEN=...
# CONFLUENCE_SPACE_KEY=TEST

# =============================================================================
# OPTIONAL: NOTIFICATIONS
# =============================================================================

# Slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL=#testops-alerts

# Email (SMTP)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=...
# EMAIL_PASSWORD=...
# EMAIL_FROM=testops@your-company.com

# Pushover
# PUSHOVER_USER_KEY=...
# PUSHOVER_APP_TOKEN=...
