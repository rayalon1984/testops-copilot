# API Configuration
VITE_API_URL=http://localhost:3000
VITE_WEBSOCKET_URL=ws://localhost:3000

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# Authentication
VITE_AUTH_PROVIDER=local # local, github, google
VITE_AUTH_DOMAIN=
VITE_AUTH_CLIENT_ID=

# External Services
VITE_JENKINS_URL=
VITE_GITHUB_API_URL=https://api.github.com
VITE_SLACK_APP_ID=

# Monitoring
VITE_SENTRY_DSN=
VITE_LOG_LEVEL=info # debug, info, warn, error

# UI Configuration
VITE_APP_NAME=TestOps Copilot
VITE_DEFAULT_THEME=light # light, dark, system
VITE_DEFAULT_LANGUAGE=en
VITE_ENABLE_DARK_MODE=true

# Performance
VITE_ENABLE_QUERY_CACHE=true
VITE_CACHE_TTL=300000 # 5 minutes in milliseconds