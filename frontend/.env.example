# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_TIMEOUT=30000

# Authentication
VITE_AUTH_STORAGE_KEY=testops_auth
VITE_AUTH_REFRESH_INTERVAL=300000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=true

# External Services
VITE_JENKINS_URL=http://your-jenkins-url
VITE_GITHUB_API_URL=https://api.github.com

# Notification Settings
VITE_NOTIFICATION_REFRESH_INTERVAL=60000
VITE_PUSHOVER_APP_URL=https://pushover.net/apps

# Test Management
VITE_TESTRAIL_URL=https://your-instance.testrail.com
VITE_XRAY_CLOUD_URL=https://xray.cloud.getxray.app

# UI Configuration
VITE_APP_NAME=TestOps Companion
VITE_APP_LOGO_URL=/logo.svg
VITE_DEFAULT_THEME=light
VITE_DEFAULT_LANGUAGE=en

# Performance
VITE_ENABLE_QUERY_CACHE=true
VITE_QUERY_CACHE_TIME=300000
VITE_STALE_TIME=60000

# Monitoring
VITE_SENTRY_DSN=your-sentry-dsn
VITE_ENABLE_ERROR_REPORTING=true

# Development
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_DEBUG_LOGGING=true

# Testing
VITE_TEST_USER_EMAIL=test@example.com
VITE_TEST_USER_PASSWORD=testpassword

# Build Configuration
VITE_PUBLIC_PATH=/
VITE_BUILD_TARGET=esnext
VITE_DROP_CONSOLE=false

# Chart Configuration
VITE_CHART_REFRESH_INTERVAL=30000
VITE_CHART_ANIMATION_DURATION=750
VITE_CHART_DEFAULT_COLOR_SCHEME=blues

# Pipeline Configuration
VITE_MAX_PARALLEL_PIPELINES=5
VITE_PIPELINE_TIMEOUT=3600000
VITE_PIPELINE_CHECK_INTERVAL=10000

# Dashboard Configuration
VITE_DASHBOARD_AUTO_REFRESH=true
VITE_DASHBOARD_REFRESH_INTERVAL=60000
VITE_DASHBOARD_MAX_ITEMS=50

# Table Configuration
VITE_TABLE_PAGE_SIZE=25
VITE_TABLE_PAGE_SIZE_OPTIONS=[10,25,50,100]
VITE_TABLE_DEFAULT_SORT_DIRECTION=desc