    "lodash": "^4.17.21",
    "notistack": "^3.0.2",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.1",
    "react-router-dom": "^6.22.1",
    "react-syntax-highlighter": "^16.1.0",
    "react-toastify": "^10.0.4",
