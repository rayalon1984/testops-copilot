# Database Configuration
DATABASE_URL=postgresql://testops:testops@localhost:5432/testops

# AI Configuration (inherited from main backend)
AI_ENABLED=true
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Vector Database (optional, for semantic search)
WEAVIATE_URL=http://localhost:8081
WEAVIATE_API_KEY=

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# MCP Server Configuration
MCP_SERVER_NAME=testops-companion
MCP_SERVER_VERSION=1.0.0
LOG_LEVEL=info

# Cost Tracking
ENABLE_COST_TRACKING=true
COST_ALERT_THRESHOLD_USD=100

# Feature Flags
ENABLE_BATCH_ANALYSIS=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_AUTO_CATEGORIZATION=true
